# Default standalone example
BOT_RUNTIME_ROLE=standalone
INTERNAL_PROVIDER_MODE=package
INTERNAL_PROVIDER_PACKAGE=financial-bot-internal

# Runtime root overrides
# BOT_RUNTIME_ROOT_DIR=/absolute/path/to/runtime
# BOT_DATA_DIR=/absolute/path/to/runtime/data
# BOT_RUNS_DIR=/absolute/path/to/runtime/runs
# BOT_BENCHMARK_DIR=/absolute/path/to/runtime/benchmark
# BOT_CHARTS_DIR=/absolute/path/to/runtime/charts

# Collector
# COLLECTOR_TASKS=build-etf-aggregates,enrich-stock-cache
# COLLECTOR_INTERVAL_MS=1800000
# COLLECTOR_RUN_ON_START=true

DISCORD_BOT_TOKEN=
