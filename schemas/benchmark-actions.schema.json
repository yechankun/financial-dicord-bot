{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "actions",
    "notes",
    "error"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "actions": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "side",
          "symbol",
          "quantity",
          "price",
          "price_min",
          "price_max",
          "description",
          "holding_reason",
          "reason"
        ],
        "properties": {
          "side": {
            "type": "string",
            "enum": [
              "buy",
              "sell"
            ]
          },
          "symbol": {
            "type": "string",
            "minLength": 1
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          },
          "price": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "price_min": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "price_max": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "holding_reason": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
