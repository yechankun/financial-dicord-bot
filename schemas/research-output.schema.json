{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "key_takeaways",
    "analysis_markdown",
    "supporting_paths",
    "notes",
    "error"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "key_takeaways": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 8
    },
    "analysis_markdown": {
      "type": "string",
      "minLength": 1
    },
    "supporting_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
