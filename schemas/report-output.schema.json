{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "key_takeaways",
    "report",
    "notes",
    "error"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "key_takeaways": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 8
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_dir",
        "html_path",
        "png_paths",
        "supporting_paths"
      ],
      "properties": {
        "output_dir": {
          "type": "string",
          "minLength": 1
        },
        "html_path": {
          "type": "string",
          "minLength": 1
        },
        "png_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "supporting_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
