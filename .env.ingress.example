BOT_RUNTIME_ROLE=ingress
INTERNAL_PROVIDER_MODE=package
INTERNAL_PROVIDER_PACKAGE=financial-bot-internal

# Public repo root stays the process cwd.
# Runtime root is where synced runtime state lives on the server.
BOT_RUNTIME_ROOT_DIR=/srv/financial-bot-runtime
BOT_DATA_DIR=/srv/financial-bot-runtime/data
BOT_RUNS_DIR=/srv/financial-bot-runtime/runs
BOT_BENCHMARK_DIR=/srv/financial-bot-runtime/benchmark
BOT_CHARTS_DIR=/srv/financial-bot-runtime/charts

DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
BENCHMARK_INITIAL_CASH=10000
BENCHMARK_BUY_FEE_RATE=0.001
BENCHMARK_SELL_FEE_RATE=0.001
GUMROAD_PRODUCT_URL=https://yeongkun.gumroad.com/l/cyekst
GUMROAD_CLAIM_FIELD_NAME=ClaimCode
GUMROAD_PING_ENABLED=true
GUMROAD_PING_HOST=0.0.0.0
GUMROAD_PING_PORT=8787
GUMROAD_PING_PATH=/gumroad/ping
GUMROAD_PING_SECRET=
GUMROAD_TIER_MAP_JSON={\"basic\":\"individual_basic\",\"server basic\":\"guild_basic\"}
ALLOWED_DISCORD_USER_IDS=
