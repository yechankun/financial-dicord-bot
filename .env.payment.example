BOT_DATA_DIR=/srv/financial-bot-runtime/data
BOT_RUNS_DIR=/srv/financial-bot-runtime/runs
BOT_BENCHMARK_DIR=/srv/financial-bot-runtime/benchmark
BOT_CHARTS_DIR=/srv/financial-bot-runtime/charts

DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
