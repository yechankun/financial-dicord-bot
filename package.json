{
  "name": "financial-bot",
  "version": "0.1.0",
  "description": "Financial bot with channel adapters and a private internal runtime package.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "start:auto": "INTERNAL_PROVIDER_MODE=auto node src/index.js",
    "start:package": "INTERNAL_PROVIDER_MODE=package node src/index.js",
    "start:public": "INTERNAL_PROVIDER_MODE=disabled node src/index.js",
    "start:ingress": "BOT_RUNTIME_ROLE=ingress INTERNAL_PROVIDER_MODE=package node src/index.js",
    "start:mac": "BOT_CAPABILITIES=report-worker,collector,ai-trading INTERNAL_PROVIDER_MODE=package node src/index.js",
    "start:standalone": "BOT_RUNTIME_ROLE=standalone INTERNAL_PROVIDER_MODE=package node src/index.js",
    "check": "find src -name '*.js' -print0 | xargs -0 -n1 node --check",
    "provider:status": "node --input-type=module -e \"import('./src/gateways/internal/provider.js').then((m) => console.log(JSON.stringify(m.getInternalProviderStatus(), null, 2)))\"",
    "runtime:status": "node --input-type=module -e \"import('./src/runtimeCapabilities.js').then((m) => console.log(JSON.stringify(m.getCapabilityStatus(), null, 2)))\""
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "discord.js": "^14.21.0",
    "dotenv": "^17.2.3",
    "playwright": "^1.56.1",
    "playwright-core": "^1.58.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "optionalDependencies": {
    "financial-bot-internal": "git+ssh://git@github.com/yechankun/financial-bot-internal.git"
  }
}
