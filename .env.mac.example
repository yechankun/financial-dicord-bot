BOT_CAPABILITIES=report-worker,collector,ai-trading
INTERNAL_PROVIDER_MODE=package
INTERNAL_PROVIDER_PACKAGE=financial-bot-internal
COLLECTOR_TASKS=build-etf-aggregates,enrich-stock-cache
COLLECTOR_INTERVAL_MS=1800000
COLLECTOR_RUN_ON_START=true

# Public repo root stays the process cwd.
# Runtime root is where the Mac worker keeps its writable runtime state.
BOT_RUNTIME_ROOT_DIR=/Users/yechankun/Runtime/financial-bot-worker
BOT_DATA_DIR=/Users/yechankun/Runtime/financial-bot-worker/data
BOT_RUNS_DIR=/Users/yechankun/Runtime/financial-bot-worker/runs
BOT_BENCHMARK_DIR=/Users/yechankun/Runtime/financial-bot-worker/benchmark
BOT_CHARTS_DIR=/Users/yechankun/Runtime/financial-bot-worker/charts

# Internal package uses the same public repo for schemas/config,
# but writes runtime state under INTERNAL_RUNTIME_ROOT_DIR.
INTERNAL_WORKSPACE_DIR=/Users/yechankun/Code/bots/financial-bot
INTERNAL_RUNTIME_ROOT_DIR=/Users/yechankun/Runtime/financial-bot-worker
INTERNAL_DATA_DIR=/Users/yechankun/Runtime/financial-bot-worker/data
INTERNAL_RUNS_DIR=/Users/yechankun/Runtime/financial-bot-worker/runs
INTERNAL_BENCHMARK_DIR=/Users/yechankun/Runtime/financial-bot-worker/benchmark
INTERNAL_CHARTS_DIR=/Users/yechankun/Runtime/financial-bot-worker/charts

# Discord credentials are not required on the Mac worker unless you also run ingress there.
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
BENCHMARK_INITIAL_CASH=10000
BENCHMARK_BUY_FEE_RATE=0.001
BENCHMARK_SELL_FEE_RATE=0.001
ALLOWED_DISCORD_USER_IDS=
